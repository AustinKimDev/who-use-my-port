#!/usr/bin/env python3
import argparse
import json
import os
import re
import signal
import subprocess
import sys
import tempfile
import time
from pathlib import Path


REGISTRY_PATH = Path(
    os.environ.get(
        "WHOPORT_REGISTRY_PATH",
        str(Path.home() / "Library" / "Application Support" / "WhoUseMyPort" / "registry.json"),
    )
)


def load_registry():
    if not REGISTRY_PATH.exists():
        return []

    try:
        with REGISTRY_PATH.open("r", encoding="utf-8") as file:
            data = json.load(file)
            return data if isinstance(data, list) else []
    except (OSError, json.JSONDecodeError):
        return []


def save_registry(registry):
    REGISTRY_PATH.parent.mkdir(parents=True, exist_ok=True)
    fd, temp_path = tempfile.mkstemp(prefix="registry.", suffix=".json", dir=str(REGISTRY_PATH.parent))

    with os.fdopen(fd, "w", encoding="utf-8") as file:
        json.dump(registry, file, indent=2, sort_keys=True)
        file.write("\n")

    os.replace(temp_path, REGISTRY_PATH)


def registration_key(item):
    return (int(item.get("port", 0)), item.get("tool", ""), item.get("projectPath", ""))


def reserve(args, pid=None):
    registry = load_registry()
    now = time.time()
    project = os.path.abspath(args.project or os.getcwd())
    tool = args.tool or os.environ.get("WHOPORT_TOOL") or "unknown"
    command = args.command
    args.project = project
    args.tool = tool

    new_item = {
        "port": args.port,
        "tool": tool,
        "projectPath": project,
        "command": command,
        "purpose": args.purpose,
        "pid": pid if pid is not None else args.pid,
        "startedAt": now,
        "updatedAt": now,
    }

    key = registration_key(new_item)
    replaced = False
    for index, item in enumerate(registry):
        if registration_key(item) == key:
            existing_started_at = item.get("startedAt") or now
            new_item["startedAt"] = existing_started_at
            registry[index] = new_item
            replaced = True
            break

    if not replaced:
        registry.append(new_item)

    save_registry(registry)
    return new_item


def release(args):
    registry = load_registry()
    project = os.path.abspath(args.project) if args.project else None
    tool = args.tool or os.environ.get("WHOPORT_TOOL")

    filtered = []
    removed = []
    for item in registry:
        matches = int(item.get("port", -1)) == args.port
        if tool:
            matches = matches and item.get("tool") == tool
        if project:
            matches = matches and os.path.abspath(item.get("projectPath", "")) == project

        if matches:
            removed.append(item)
        else:
            filtered.append(item)

    save_registry(filtered)
    return removed


def heartbeat(args):
    registry = load_registry()
    project = os.path.abspath(args.project) if args.project else None
    tool = args.tool or os.environ.get("WHOPORT_TOOL")
    now = time.time()
    touched = []

    for item in registry:
        matches = int(item.get("port", -1)) == args.port
        if tool:
            matches = matches and item.get("tool") == tool
        if project:
            matches = matches and os.path.abspath(item.get("projectPath", "")) == project

        if matches:
            item["updatedAt"] = now
            if args.pid:
                item["pid"] = args.pid
            touched.append(item)

    save_registry(registry)
    return touched


def parse_lsof_field_output(output, port):
    processes = []
    current = None
    current_protocol = ""
    current_state = None

    def flush():
        if current and current.get("connections"):
            processes.append(current.copy())

    for raw_line in output.splitlines():
        if not raw_line:
            continue

        field = raw_line[0]
        value = raw_line[1:]

        if field == "p":
            flush()
            current = {"pid": int(value), "command": "", "user": "", "connections": []}
            current_protocol = ""
            current_state = None
        elif not current:
            continue
        elif field == "c":
            current["command"] = value
        elif field == "L":
            current["user"] = value
        elif field == "P":
            current_protocol = value
        elif field == "T":
            if value.startswith("ST="):
                current_state = value[3:]
            elif value.startswith("TST="):
                current_state = value[4:]
            if current["connections"]:
                current["connections"][-1]["state"] = current_state
        elif field == "f":
            current_protocol = ""
            current_state = None
        elif field == "n":
            local_endpoint = value.split("->", 1)[0]
            match = re.search(r":(\d+)(?:\s|\)|$)", local_endpoint)
            local_port = int(match.group(1)) if match else None
            if local_port == port:
                current["connections"].append(
                    {
                        "protocol": current_protocol or "UNKNOWN",
                        "state": current_state or "UNKNOWN",
                        "name": value,
                    }
                )

    flush()
    return processes


def lsof_for_port(port):
    output = ""
    for selector in (f"-iTCP:{port}", f"-iUDP:{port}"):
        try:
            result = subprocess.run(
                ["/usr/sbin/lsof", "-nP", "-F", "pcLnPT", selector],
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                check=False,
            )
            if result.stdout:
                output += result.stdout
        except OSError:
            pass

    return parse_lsof_field_output(output, port)


def check(args):
    registrations = [item for item in load_registry() if int(item.get("port", -1)) == args.port]
    processes = lsof_for_port(args.port)
    status = "occupied" if processes else ("reserved" if registrations else "available")
    payload = {
        "port": args.port,
        "status": status,
        "processes": processes,
        "registrations": registrations,
    }
    print(json.dumps(payload, indent=2, sort_keys=True))
    return 0


def wrap(args):
    if not args.command_args:
        print("whoport wrap requires a command after --", file=sys.stderr)
        return 2

    command = args.command or " ".join(args.command_args)
    args.command = command
    child = subprocess.Popen(args.command_args)
    reserve(args, pid=child.pid)

    def forward(signum, _frame):
        try:
            child.send_signal(signum)
        except ProcessLookupError:
            pass

    signal.signal(signal.SIGTERM, forward)
    signal.signal(signal.SIGINT, forward)

    try:
        return child.wait()
    finally:
        release(args)


def print_hook(_args):
    print(
        """
# Add this to your shell or AI runner bootstrap.
whoport_run() {
  local port="$1"
  shift
  whoport wrap "$port" --tool "${WHOPORT_TOOL:-manual}" --project "$PWD" -- "$@"
}
""".strip()
    )
    return 0


def main():
    parser = argparse.ArgumentParser(prog="whoport")
    subparsers = parser.add_subparsers(dest="command", required=True)

    check_parser = subparsers.add_parser("check", help="Check local listener and AI usage for a port")
    check_parser.add_argument("port", type=int)
    check_parser.set_defaults(func=check)

    reserve_parser = subparsers.add_parser("reserve", help="Register AI/tool usage for a port")
    reserve_parser.add_argument("port", type=int)
    reserve_parser.add_argument("--tool")
    reserve_parser.add_argument("--project")
    reserve_parser.add_argument("--command")
    reserve_parser.add_argument("--purpose")
    reserve_parser.add_argument("--pid", type=int)
    reserve_parser.set_defaults(func=lambda args: (print(json.dumps(reserve(args), indent=2, sort_keys=True)), 0)[1])

    heartbeat_parser = subparsers.add_parser("heartbeat", help="Refresh an existing registration")
    heartbeat_parser.add_argument("port", type=int)
    heartbeat_parser.add_argument("--tool")
    heartbeat_parser.add_argument("--project")
    heartbeat_parser.add_argument("--pid", type=int)
    heartbeat_parser.set_defaults(func=lambda args: (print(json.dumps(heartbeat(args), indent=2, sort_keys=True)), 0)[1])

    release_parser = subparsers.add_parser("release", help="Remove AI/tool usage registration")
    release_parser.add_argument("port", type=int)
    release_parser.add_argument("--tool")
    release_parser.add_argument("--project")
    release_parser.set_defaults(func=lambda args: (print(json.dumps(release(args), indent=2, sort_keys=True)), 0)[1])

    list_parser = subparsers.add_parser("list", help="List registered AI/tool usage")
    list_parser.set_defaults(func=lambda _args: (print(json.dumps(load_registry(), indent=2, sort_keys=True)), 0)[1])

    wrap_parser = subparsers.add_parser("wrap", help="Run a command while registering its port usage")
    wrap_parser.add_argument("port", type=int)
    wrap_parser.add_argument("--tool")
    wrap_parser.add_argument("--project")
    wrap_parser.add_argument("--command")
    wrap_parser.add_argument("--purpose")
    wrap_parser.add_argument("command_args", nargs=argparse.REMAINDER)
    wrap_parser.set_defaults(func=wrap)

    hook_parser = subparsers.add_parser("hook", help="Print shell hook helper")
    hook_parser.set_defaults(func=print_hook)

    args = parser.parse_args()
    if getattr(args, "command_args", None) and args.command_args[:1] == ["--"]:
        args.command_args = args.command_args[1:]

    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
